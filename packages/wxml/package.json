{
  "name": "@tofrankie/eslint-plugin-wxml",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "description": "eslint plugin for wxml",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/eslint-plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/eslint-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/tofrankie/eslint-plugin/issues"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslint-plugin-wxml",
    "miniprogram",
    "wxml",
    "tofrankie"
  ],
  "exports": "./dist/index.cjs",
  "main": "./dist/index.cjs",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint . --cache --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "update:docs": "eslint-doc-generator",
    "publint": "publint",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@typescript-eslint/utils": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "eslint-plugin-eslint-plugin": "catalog:dev"
  }
}
